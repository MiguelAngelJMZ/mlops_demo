# Versión alternativa: job que crea un cluster nuevo en cada ejecución.
# No se incluye en el bundle (no está en include de databricks.yml).
# Para usarla: renombrar a jobs.yml (y respaldar el jobs.yml actual con cluster existente).
#
# Job único que: 1) genera datos sintéticos, 2) entrena y registra el modelo.
resources:
  jobs:
    demo_mlops_job:
      name: "[${bundle.target}] MLOps Demo - Generate Data & Train"
      tasks:
        - task_key: generate_synthetic_data
          notebook_task:
            notebook_path: ../src/notebooks/generate_synthetic_data.py
            base_parameters:
              catalog: ${var.catalog}
              schema: ${var.schema}
          new_cluster:
            spark_version: "14.3.x-scala2.12"
            node_type_id: "i3.xlarge"
            num_workers: 0
            spark_conf:
              spark.databricks.cluster.profile: singleNode
              spark.master: local[*]
            custom_tags:
              ResourceClass: SingleNode
        - task_key: train_model
          depends_on:
            - task_key: generate_synthetic_data
          notebook_task:
            notebook_path: ../src/notebooks/train_model.py
            base_parameters:
              catalog: ${var.catalog}
              schema: ${var.schema}
          new_cluster:
            spark_version: "14.3.x-scala2.12"
            node_type_id: "i3.xlarge"
            num_workers: 0
            spark_conf:
              spark.databricks.cluster.profile: singleNode
              spark.master: local[*]
            custom_tags:
              ResourceClass: SingleNode
      permissions:
        - level: CAN_VIEW
          group_name: users
        - level: CAN_MANAGE_RUN
          group_name: users
